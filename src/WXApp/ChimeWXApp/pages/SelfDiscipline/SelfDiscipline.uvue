<template>
	<view class="page" :class="{ 'page-scroll-locked': modalVisible }">
		<!-- ===== Header ===== -->
		<view class="header">
			<view class="header-deco deco-1"></view>
			<view class="header-deco deco-2"></view>

			<!-- 版本切换 -->
			<view class="header-top">
				<view class="toggle-btn" @click="switchToHappy">
					<view class="toggle-icon">🔀</view>
					<view class="toggle-text">欢乐版</view>
				</view>
			</view>

			<!-- 问候 + 连续打卡 -->
			<view class="header-main">
				<view class="greeting">
					<view class="greeting-date">{{ greetingDate }}</view>
					<view class="greeting-text">{{ greetingText }}</view>
				</view>
				<view class="streak-badge">
					<view class="streak-label">🔥 连续打卡</view>
					<view class="streak-days">7 天</view>
				</view>
			</view>

			<!-- 卡路里数据 + 营养素 -->
			<view class="header-stats">
				<!-- 圆形进度显示 -->
				<view class="progress-ring" :style="{ background: 'conic-gradient(#FBBF24 ' + intakePercent + '%, rgba(255,255,255,0.2) 0%)' }">
					<view class="progress-inner">
						<view class="percent-value">{{ intakePercent }}%</view>
						<view class="percent-label">已摄入</view>
